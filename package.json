{
  "name": "fluxerbothelper",
  "displayName": "Fluxer.py Bot Helper",
  "description": "",
  "version": "0.0.1",
  "publisher": "ERR0RW0LF",
  "author": {
    "name": "ERR0RW0LF"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ERR0RW0LF/fluxer_bot_extension"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fluxerbothelper.helloWorld",
        "category": "Fluxer",
        "title": "Hello World"
      },
      {
        "command": "fluxerbothelper.setupCog",
        "category": "Fluxer",
        "title": "Setup Cog"
      },
      {
        "command": "fluxerbothelper.createCog",
        "category": "Fluxer",
        "title": "Create Cog"
      },
      {
        "command": "fluxerbothelper.addCogCommand",
        "category": "Fluxer",
        "title": "Create Command in Cog"
      },
      {
        "command": "fluxerbothelper.addBotCommand",
        "category": "Fluxer",
        "title": "Create Command in Bot"
      }
    ],
    "menus": {
      "file/newFile": [
        {
          "command": "fluxerbothelper.createCog",
          "group": "file",
          "when": "!virtualWorkspace"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
